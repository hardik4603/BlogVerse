<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    
    <title>Blog</title>
</head>
<body>
    <%- include('./partials/nav') %>
        
        <div class="container mt-4">
            <h1><%= blog.title %></h1>
            <img src="<%= blog.coverImageURL %>" alt="cover-Img" width="700px">
            <pre class="mt-3"><%= blog.body %></pre>
        </div>

        <div class="container mt-4">
            <img src="<%= blog.createdBy.profileImageURL %>" width="50px" alt="">
            <span><%= blog.createdBy.fullName %></span>
        </div>
       
        <div class="container mt-3">
            <h2>Comments(<%= comments.length %>)</h2>
            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="post">
                    <div class="flex justify-center">
                        <input type="text" class="form-control" id="content" name="content" aria-describedby="content"/>
                        <button class="mt-2 btn btn-primary"> Add Comment </button>
                    </div>
                </form>
            <% } %>

            <div class="comments mt-3">
                <% comments.forEach((comment) => { %>
                    <div class="mb-3 d-flex gap-3 flex-row align-items-center justify-start">
                        <img src="<%= comment.createdBy.profileImageURL %>" width="40px" alt="">
                        <div class="d-flex flex-column justify-start">
                            <h5><%= comment.createdBy.fullName %></h5>
                            <h6><%= comment.content %></h6>
                        </div>
                        
                    </div>

                <% }) %>
            </div>
        </div> 
    <%- include('./partials/script') %>
</body>
</html>